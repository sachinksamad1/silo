{
  "name": "silo-desktop",
  "version": "1.0.0",
  "description": "Silo - Privacy-first journaling desktop app",
  "main": "dist/main.js",
  "scripts": {
    "build:renderer": "nx build web",
    "build": "npm run build:renderer && electron-builder --win --mac --linux",
    "dev": "npm run build:renderer && electron ."
  },
  "build": {
    "appId": "com.silo.app",
    "productName": "Silo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/.next",
        "to": "renderer"
      }
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.0"
  }
}
