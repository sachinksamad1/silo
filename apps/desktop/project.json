{
  "name": "desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/desktop",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "SILO_DEV=true electron .",
        "cwd": "apps/desktop"
      }
    },
    "compile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc main.ts preload.ts --outDir dist --module CommonJS --target ES2020 --esModuleInterop --skipLibCheck",
        "cwd": "apps/desktop"
      }
    }
  },
  "implicitDependencies": ["web"]
}
