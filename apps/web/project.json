{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project web --web",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --webpack -p 4000",
        "cwd": "apps/web"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build --webpack",
        "cwd": "apps/web"
      },
      "outputs": [
        "{projectRoot}/.next"
      ]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start -p 4000",
        "cwd": "apps/web"
      }
    }
  }
}
